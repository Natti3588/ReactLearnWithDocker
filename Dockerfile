# 1. ベースとなる環境（Node.jsが入った空っぽのパソコン）を用意する
FROM node:20-alpine

# 2. コンテナ（仮想環境）の中での作業フォルダを「/app」に決める
WORKDIR /app

# 3. まず、パッケージの設計図（package.jsonなど）だけをコンテナにコピーする
COPY package*.json ./

# 4. 設計図をもとに、必要なパッケージ（ReactやViteなど）をインストールする
RUN npm install

# 5. 残りのすべてのファイル（自分が書いたソースコードなど）をコンテナにコピーする
COPY . .

# 6. Viteの開発サーバーが使う「5173番」の扉（ポート）を開けておく
EXPOSE 5173

# 7. コンテナが起動したときに、自動で実行するコマンド
CMD ["npm", "run", "dev", "--", "--host"]